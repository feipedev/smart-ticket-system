{
    "name": "seu-nome/smart-ticket-system",
    "description": "Sistema de Ordens de Serviço com PHP 7.4, MVC, Repository Pattern, JWT Auth e API REST",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "firebase/php-jwt": ">=5.0,<5.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "serve": "php -S localhost:8080 -t public/",
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "audit": {
            "ignore": [
                "PKSA-y2cr-5h3j-g3ys",
                "PKSA-2kqm-ps5x-s4f5"
            ]
        }
    }
}
